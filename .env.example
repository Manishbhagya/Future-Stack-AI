# ── Clerk Authentication (Required for deployment) ──
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard
CLERK_WEBHOOK_SECRET=         # Required for user profile sync webhook

# ── Supabase (Required for deployment) ──
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ── AI / OpenRouter (Required for chat features) ──
OPENROUTER_API_KEY=
OPENROUTER_REFERER=
OPENROUTER_MODEL=nvidia/nemotron-3-nano-omni-30b-a3b-reasoning:free

# ── Site Configuration ──
NEXT_PUBLIC_SITE_URL=https://future-stack-ai.vercel.app
